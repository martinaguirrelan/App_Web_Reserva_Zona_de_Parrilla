# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtenlos en: https://supabase.com/dashboard → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-key
# Service role key (para signed URLs en buckets privados — Settings → API → service_role)
SUPABASE_SERVICE_KEY=your-service-role-key

# ── PostgreSQL (Supabase connection string) ───────────────────────────────────
# Supabase → Settings → Database → Connection string → URI
# Reemplaza [YOUR-PASSWORD] con tu contraseña de Supabase
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
